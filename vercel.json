{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "projects.nguyendevs.io.vn" }
      ],
      "destination": "/projects.html"
    },
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "info.nguyendevs.io.vn" }
      ],
      "destination": "/info.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "functions": {
    "api/music.js": {
      "includeFiles": "assets/music/**"
    }
  },
  "crons": [
    {
      "path": "/api/tiktok-stats",
      "schedule": "0 1 * * *"
    }
  ]
}