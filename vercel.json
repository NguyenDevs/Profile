{
  "version": 2,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "functions": {
    "api/music.js": {
      "includeFiles": "assets/music/**"
    }
  },
  "crons": [
    {
      "path": "/api/tiktok-stats",
      "schedule": "0 1 * * *"
    }
  ]
}
